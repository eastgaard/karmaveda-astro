---
import Layout from '../layouts/Layout.astro';
import TextWithImage from '../components/TextWithImage.astro';
---

<Layout 
  title="Om Karmaveda | Holistisk Velværeklinik" 
  description="Karmaveda er en holistisk velværeklinik fokuseret på Ayurvediske behandlinger. Læs om vores filosofi og kontakt os."
>
  <!-- Hero Section -->
  <div class="w-full bg-gradient-to-br from-kv-earth-50 to-kv-earth-200 pt-32 pb-24 border-b border-kv-earth-300/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-[#606c38] mb-6 leading-tight font-bold">
        Velkommen til Karmaveda
      </h1>
      <p class="text-xl md:text-2xl text-[#606c38]/80 font-light leading-relaxed max-w-3xl mx-auto">
        Holistisk velværeklinik med fokus på Ayurvediske behandlinger
      </p>
    </div>
  </div>

  <!-- Intro TextWithImage -->
  <TextWithImage 
    imageSrc="https://images.unsplash.com/photo-1545205597-3d9d02c29597?q=80&w=1000&auto=format&fit=crop" 
    imageAlt="Karmaveda Klinikken" 
    imagePosition="right"
    title="Karmaveda"
    subtitle="Vores Filosofi"
    bgColor="white"
    buttonText="Læs mere om stifter Nina Riisager"
    buttonHref="/om-nina-riisager"
  >
    <p>
      Vi tilbyder holistiske Ayurvediske behandlinger og livsstilskonsultationer. Vores mål er at bringe balance til din krop og dit sind gennem evidensbaserede, holistiske metoder.
    </p>
    <p>
      Hos Karmaveda tror vi på, at ægte velvære kommer indefra. Gennem ayurveda, meditation og balancerende energibehandlinger hjælper vi dig med at genfinde roen i en travl hverdag og skabe langtidsholdbare forandringer.
    </p>
  </TextWithImage>

  <!-- Kontakt & Information -->
  <section class="py-24 bg-kv-earth-50 border-t border-kv-earth-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-serif text-kv-green-900 mb-4">Praktisk Information</h2>
        <p class="text-kv-text/70">Find os eller kontakt os for at høre mere.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        
        <!-- Kontaktkort -->
        <div class="bg-white p-10 rounded-3xl shadow-lg border border-kv-earth-200 hover:shadow-xl transition-shadow relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-kv-green-100 rounded-bl-full -mr-16 -mt-16 opacity-50"></div>
          <h3 class="text-2xl font-serif text-kv-green-900 mb-6 relative z-10">Kontakt</h3>
          
          <div class="space-y-6 relative z-10">
            <div class="flex items-start">
              <svg class="w-6 h-6 text-kv-green-600 mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-medium text-kv-green-900">Karmaveda.dk</p>
                <p class="text-kv-text/70">Dam Holme 14</p>
                <p class="text-kv-text/70">3660 Stenløse</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <svg class="w-6 h-6 text-kv-green-600 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <p class="text-kv-text/80">+45 29 72 59 04</p>
            </div>
            
            <div class="flex items-center">
              <svg class="w-6 h-6 text-kv-green-600 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:nina@karmaveda.dk" class="text-kv-green-700 hover:text-kv-green-900 transition-colors">nina@karmaveda.dk</a>
            </div>
          </div>
        </div>

        <!-- Virksomhedskort -->
        <div class="bg-white p-10 rounded-3xl shadow-lg border border-kv-earth-200 hover:shadow-xl transition-shadow relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-kv-earth-100 rounded-bl-full -mr-16 -mt-16 opacity-50"></div>
          <h3 class="text-2xl font-serif text-kv-green-900 mb-6 relative z-10">Virksomhedsoplysninger</h3>
          
          <div class="space-y-4 relative z-10">
            <div class="flex justify-between items-center border-b border-kv-earth-100 pb-3">
              <span class="text-kv-text/60">CVR</span>
              <span class="font-medium text-kv-green-900">DK34226679</span>
            </div>
            <div class="flex justify-between items-center border-b border-kv-earth-100 pb-3">
              <span class="text-kv-text/60">Bank</span>
              <span class="font-medium text-kv-green-900 text-right">Reg: 8117<br>Konto: 0002909248</span>
            </div>
            <div class="flex justify-between items-center border-b border-kv-earth-100 pb-3">
              <span class="text-kv-text/60">IBAN</span>
              <span class="font-medium text-kv-green-900 text-sm">DK3181170002909248</span>
            </div>
            <div class="flex justify-between items-center pb-2">
              <span class="text-kv-text/60">SWIFT/BIC</span>
              <span class="font-medium text-kv-green-900">NYKBDKKK</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
