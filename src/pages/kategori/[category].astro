---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // Udvind alle unikke kategorier fra posts
  const uniqueCategories = [...new Set(allPosts.map((post) => post.data.category))].filter(Boolean);
  
  return uniqueCategories.map((category) => {
    // Find posts der hører til denne kategori
    const filteredPosts = allPosts.filter((post) => post.data.category === category);
    
    // Sorter dem efter dato (nyeste først)
    filteredPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
    
    // Lav en URL-venlig "slug" (fx "Mindfulness og Meditation" -> "mindfulness-og-meditation")
    const categorySlug = category.toLowerCase()
      .replace(/æ/g, 'ae')
      .replace(/ø/g, 'oe')
      .replace(/å/g, 'aa')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)+/g, '');
    
    return {
      params: { category: categorySlug },
      props: { posts: filteredPosts, categoryName: category },
    };
  });
}

const { category } = Astro.params;
const { posts, categoryName } = Astro.props;
---

<Layout 
  title={`Kategori: ${categoryName} | Karmaveda`}
  description={`Læs alle mine artikler om ${categoryName}. Få inspiration til balance og velvære.`}
>
  <!-- Hero Section for Kategorien -->
  <div class="w-full bg-gradient-to-br from-[#fefae0] to-[#e9edc9] pt-32 pb-24 border-b border-[#dda15e]/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-sm font-semibold text-[#dda15e] uppercase tracking-widest mb-4">
        Kategori
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-[#606c38] mb-6 leading-tight font-bold">
        {categoryName}
      </h1>
      <p class="text-xl text-[#606c38]/80 font-light leading-relaxed max-w-2xl mx-auto">
        Udforsk mine seneste artikler og indsigter inden for <strong>{categoryName}</strong>.
      </p>
    </div>
  </div>

  <!-- Artikel Oversigt Grid -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {posts.map((post) => (
          <article class="group flex flex-col bg-white border border-[#dda15e]/20 rounded-3xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            {post.data.image ? (
              <a href={`/blog/${post.id}`} class="block aspect-[4/3] overflow-hidden relative">
                <div class="absolute inset-0 bg-[#606c38]/10 group-hover:bg-transparent transition-colors z-10"></div>
                <Image 
                  src={post.data.image} 
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                />
              </a>
            ) : (
              <a href={`/blog/${post.id}`} class="block aspect-[4/3] bg-gradient-to-br from-[#fefae0] to-[#e9edc9] flex items-center justify-center relative overflow-hidden">
                <div class="absolute inset-0 bg-[#dda15e]/5 group-hover:bg-[#dda15e]/10 transition-colors"></div>
                <svg class="w-20 h-20 text-[#606c38]/20" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z" />
                </svg>
              </a>
            )}
            <div class="p-8 flex flex-col flex-grow">
              <h2 class="text-2xl font-serif text-[#606c38] mb-4 group-hover:text-[#dda15e] transition-colors">
                <a href={`/blog/${post.id}`} class="block">
                  {post.data.title}
                </a>
              </h2>
              {post.data.description && (
                <p class="text-[#606c38]/70 font-light leading-relaxed mb-6 flex-grow line-clamp-3">
                  {post.data.description}
                </p>
              )}
              <div class="mt-auto flex items-center text-sm font-medium text-[#dda15e] group-hover:text-[#606c38] transition-colors">
                Læs artiklen
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </div>
            </div>
          </article>
        ))}
      </div>
      
      <div class="mt-20 text-center">
        <a href="/blog" class="inline-flex items-center justify-center px-8 py-4 border border-[#dda15e] text-[#606c38] hover:bg-[#dda15e] hover:text-white rounded-full font-medium transition-all duration-300">
          Se alle artikler
        </a>
      </div>
    </div>
  </section>
</Layout>
