---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Karmaveda | Din Lokale Ayurvediske Velværeklinik" description="Oplev ægte velvære hos Karmaveda med holistiske Ayurvediske behandlinger, massage og Shirodhara. Find din indre balance og ro.">
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center py-20 overflow-hidden">
    <!-- Baggrundsbillede -->
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-bg.png" alt="Ayurvedisk wellness atmosfære" class="w-full h-full object-cover object-center" />
      <!-- Soft Overlay for readability -->
      <div class="absolute inset-0 bg-kv-earth-50/70 backdrop-blur-[2px]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-kv-earth-50/90 via-kv-earth-50/60 to-transparent"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-2xl">
        <span class="text-sm font-semibold text-kv-green-700 uppercase tracking-widest mb-4 block">Velkommen til Karmaveda</span>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-serif text-kv-green-900 mb-6 leading-[1.1]">
          Find din indre balance med Ayurveda
        </h1>
        <p class="text-lg sm:text-xl text-kv-text/90 mb-10 max-w-lg leading-relaxed font-light">
          Oplev ægte velvære gennem holistiske behandlinger. Vi skaber ro i sindet og sundhed i kroppen gennem ældgammel indisk visdom.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/booking" class="inline-flex justify-center items-center px-8 py-3.5 border border-transparent text-base font-medium rounded-full text-white bg-kv-green-600 hover:bg-kv-green-800 transition-all duration-300 shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
            Book Behandling
          </a>
          <a href="/om-karmaveda" class="inline-flex justify-center items-center px-8 py-3.5 border-2 border-kv-green-600 text-base font-medium rounded-full text-kv-green-700 hover:bg-kv-green-50 transition-all duration-300">
            Læs Mere
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Services -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20">
        <span class="text-sm font-semibold text-kv-earth-600 uppercase tracking-widest mb-3 block">Holistisk Velvære</span>
        <h2 class="text-4xl font-serif text-kv-green-900 mb-6">Vores Behandlinger</h2>
        <p class="text-lg text-kv-text/70 max-w-2xl mx-auto font-light">Skræddersyede forløb, der understøtter din krops naturlige evne til at helbrede sig selv.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Service 1 -->
        <div class="bg-kv-earth-50 rounded-3xl p-10 hover:shadow-xl transition-all duration-300 group border border-kv-earth-200/50 hover:border-kv-green-300 transform hover:-translate-y-1">
          <div class="w-14 h-14 bg-kv-green-100 rounded-full flex items-center justify-center mb-8 group-hover:bg-kv-green-500 transition-colors duration-300 shadow-inner">
            <svg class="w-7 h-7 text-kv-green-700 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-kv-green-900 mb-4">Ayurvedisk Massage</h3>
          <p class="text-base text-kv-text/80 leading-relaxed mb-8 font-light">Dybdegående og afslappende olie-massage (Abhyanga), der balancerer doshaerne og fjerner spændinger.</p>
          <a href="/behandlinger/massage" class="text-kv-earth-600 font-medium hover:text-kv-green-700 flex items-center group-hover:underline transition-colors">
            Læs mere 
            <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Service 2 -->
        <div class="bg-kv-earth-50 rounded-3xl p-10 hover:shadow-xl transition-all duration-300 group border border-kv-earth-200/50 hover:border-kv-green-300 transform hover:-translate-y-1">
          <div class="w-14 h-14 bg-kv-green-100 rounded-full flex items-center justify-center mb-8 group-hover:bg-kv-green-500 transition-colors duration-300 shadow-inner">
            <svg class="w-7 h-7 text-kv-green-700 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-kv-green-900 mb-4">Shirodhara</h3>
          <p class="text-base text-kv-text/80 leading-relaxed mb-8 font-light">Beroligende behandling med varm olie, der hældes i en kontinuerlig strøm over panden for ultimativ afstressning.</p>
          <a href="/behandlinger/shirodhara" class="text-kv-earth-600 font-medium hover:text-kv-green-700 flex items-center group-hover:underline transition-colors">
            Læs mere 
            <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Service 3 -->
        <div class="bg-kv-earth-50 rounded-3xl p-10 hover:shadow-xl transition-all duration-300 group border border-kv-earth-200/50 hover:border-kv-green-300 transform hover:-translate-y-1">
          <div class="w-14 h-14 bg-kv-green-100 rounded-full flex items-center justify-center mb-8 group-hover:bg-kv-green-500 transition-colors duration-300 shadow-inner">
            <svg class="w-7 h-7 text-kv-green-700 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-kv-green-900 mb-4">Konsultation</h3>
          <p class="text-base text-kv-text/80 leading-relaxed mb-8 font-light">Få en personlig profilering af din kropstype (Prakriti) og specifikke råd til kost og livsstil.</p>
          <a href="/behandlinger/konsultation" class="text-kv-earth-600 font-medium hover:text-kv-green-700 flex items-center group-hover:underline transition-colors">
            Læs mere 
            <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Alternating Content Section 1: Text Left, Image Right -->
  <section class="py-24 bg-kv-earth-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-16">
        <!-- Text -->
        <div class="w-full md:w-1/2">
          <span class="text-sm font-semibold text-kv-green-600 uppercase tracking-widest mb-3 block">Autentisk Balance</span>
          <h2 class="text-3xl sm:text-4xl font-serif text-kv-green-900 mb-6">Den Holistiske Tilgang</h2>
          <p class="text-lg text-kv-text/80 mb-6 leading-relaxed font-light">
            Ayurveda er mere end blot massage; det er videnskaben om livet. Ved at forstå din unikke kropskonstitution (Dosha) skræddersyr vi varme olier, urter og tryk, der taler direkte til dit nervesystem.
          </p>
          <p class="text-lg text-kv-text/80 mb-8 leading-relaxed font-light">
            Vores olier er nøje udvalgt og tempereret for at trænge dybt ind i vævet, løsne op for stagneret energi og efterlade dig med en følelse af dyb, indre ro og fornyet vitalitet.
          </p>
          <a href="/om-karmaveda" class="inline-flex items-center text-kv-green-700 font-medium hover:text-kv-green-900 group transition-colors">
            Læs om vores filosofi
            <svg class="ml-2 w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <!-- Image -->
        <div class="w-full md:w-1/2">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl aspect-4/3 group">
            <img src="/images/holistic-approach.png" alt="Varm Ayurvedisk olie hældes op" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 ring-1 ring-inset ring-kv-earth-900/10 rounded-3xl pointer-events-none"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Alternating Content Section 2: Image Left, Text Right -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row-reverse items-center gap-16">
        <!-- Text -->
        <div class="w-full md:w-1/2">
          <span class="text-sm font-semibold text-kv-green-600 uppercase tracking-widest mb-3 block">Din Oase</span>
          <h2 class="text-3xl sm:text-4xl font-serif text-kv-green-900 mb-6">Træd Ind I Roen</h2>
          <p class="text-lg text-kv-text/80 mb-6 leading-relaxed font-light">
            Fra det øjeblik du træder ind ad døren hos Karmaveda, omfavnes du af en atmosfære skabt til total afslapning. Duften af æteriske olier, bløde jordfarver og dæmpet belysning sætter scenen for din rejse mod balance.
          </p>
          <p class="text-lg text-kv-text/80 mb-8 leading-relaxed font-light">
            Vores klinik er dit frirum fra hverdagens larm – et sted hvor du kan trække vejret helt ned i maven, give slip på stress og lade op med fornyet energi.
          </p>
          <a href="/klinikken" class="inline-flex items-center text-kv-green-700 font-medium hover:text-kv-green-900 group transition-colors">
            Se mere af klinikken
            <svg class="ml-2 w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <!-- Image -->
        <div class="w-full md:w-1/2">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl aspect-4/3 group">
            <img src="/images/clinic-atmosphere.png" alt="Beroligende klinik atmosfære" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 ring-1 ring-inset ring-kv-earth-900/10 rounded-3xl pointer-events-none"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
