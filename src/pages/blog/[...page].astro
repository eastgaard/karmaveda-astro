---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths, Page } from 'astro';
import PageHero from '../../components/PageHero.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog');
  const publishedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
  
  // Sætter grænsen til 9 artikler per side for at få et pænt 3x3 grid
  return paginate(publishedPosts, { pageSize: 9 });
}) satisfies GetStaticPaths;

type Props = {
  page: Page<CollectionEntry<'blog'>>;
};

const { page } = Astro.props;
---

<Layout title={page.currentPage > 1 ? `Blog - Side ${page.currentPage} | Karmaveda` : "Blog | Karmaveda"} description="Læs spændende artikler og få inspiration om Ayurveda, meditation, velvære og balance i hverdagen.">
  <PageHero theme="green">
    <span class="text-sm font-semibold text-kv-green-600 uppercase tracking-widest mb-4 block">Inspiration</span>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-kv-green-900 mb-6 leading-tight font-bold">
      Blog & Artikler
    </h1>
    <p class="text-xl md:text-2xl text-kv-green-800/80 font-light leading-relaxed max-w-2xl mx-auto mb-8">
      Få viden og inspiration til et liv i balance
    </p>
  </PageHero>

  <section class="py-16 bg-white min-h-[40vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {page.data.length === 0 ? (
        <div class="text-center text-kv-text/60 italic py-12">
          Der er endnu ingen artikler. Tjek tilbage senere!
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {page.data.map((post) => (
            <article class="bg-kv-earth-50 rounded-3xl overflow-hidden shadow-sm border border-kv-earth-200 hover:shadow-xl transition-all duration-300 flex flex-col group">
              {post.data.image && (
                <div class="aspect-video w-full overflow-hidden">
                  <Image 
                    src={post.data.image} 
                    alt={post.data.title} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                  />
                </div>
              )}
              <div class="p-8 flex flex-col flex-grow">
                <h2 class="text-2xl font-serif text-kv-green-900 mb-4 group-hover:text-kv-green-600 transition-colors">
                  <a href={`/blog/${post.id}`} class="block">
                    {post.data.title}
                  </a>
                </h2>
                {post.data.description && (
                  <p class="text-kv-text/80 mb-6 flex-grow line-clamp-3">
                    {post.data.description}
                  </p>
                )}
                <div class="mt-auto">
                  <a 
                    href={`/blog/${post.id}`} 
                    class="inline-flex items-center text-kv-green-700 font-medium hover:text-kv-green-500 transition-colors"
                  >
                    Læs mere
                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}

      {/* Pagination Controls */}
      {(page.url.prev || page.url.next) && (
        <div class="flex flex-col sm:flex-row items-center justify-between mt-20 pt-8 border-t border-kv-earth-200 gap-6">
          <div class="w-full sm:w-1/3 flex justify-start">
            {page.url.prev ? (
              <a href={page.url.prev} class="inline-flex items-center text-kv-green-700 font-medium hover:text-kv-green-500 transition-colors px-6 py-3 border border-kv-green-700 rounded-full hover:bg-kv-green-50">
                <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Forrige side
              </a>
            ) : <span />}
          </div>
          <div class="w-full sm:w-1/3 flex justify-center text-kv-text/60 font-medium">
            Side {page.currentPage} af {page.lastPage}
          </div>
          <div class="w-full sm:w-1/3 flex justify-end">
            {page.url.next ? (
              <a href={page.url.next} class="inline-flex items-center text-kv-green-700 font-medium hover:text-kv-green-500 transition-colors px-6 py-3 border border-kv-green-700 rounded-full hover:bg-kv-green-50">
                Næste side
                <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ) : <span />}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>
