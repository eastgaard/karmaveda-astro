---
// src/components/Footer.astro
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-kv-green-900 text-kv-earth-100 pt-16 pb-8 border-t border-kv-green-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      
      <!-- Brand & About -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center text-white hover:text-kv-green-200 transition-colors mb-4" aria-label="Karmaveda Forside">
          <Logo className="h-12 w-12" />
          <span class="ml-3 text-3xl font-serif tracking-wide font-medium">Karmaveda</span>
        </a>
        <p class="text-kv-earth-300 text-sm leading-relaxed mb-6 max-w-md">
          Oplev ægte velvære og indre ro. Få balance i krop og sind med skræddersyede ayurvediske behandlinger, livsstilskonsultation og meditation.
        </p>
      </div>

      <!-- Contact Info -->
      <div class="col-span-1">
        <h3 class="text-lg font-serif text-white mb-4">Kontakt</h3>
        <ul class="space-y-3 text-sm text-kv-earth-300">
          <li class="flex items-start">
            <svg class="h-5 w-5 mr-2 text-kv-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Dam Holme 14<br />3660 Stenløse</span>
          </li>
          <li class="flex items-center">
            <svg class="h-5 w-5 mr-2 text-kv-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+4529725904" class="hover:text-white transition-colors">+45 29 72 59 04</a>
          </li>
          <li class="flex items-center">
            <svg class="h-5 w-5 mr-2 text-kv-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:nina@karmaveda.dk" class="hover:text-white transition-colors">nina@karmaveda.dk</a>
          </li>
        </ul>
      </div>

      <!-- Business Info -->
      <div class="col-span-1">
        <h3 class="text-lg font-serif text-white mb-4">Virksomhed</h3>
        <ul class="space-y-2 text-sm text-kv-earth-300">
          <li>CVR: DK34226679</li>
          <li>Reg: 8117 Konto: 0002909248</li>
          <li>IBAN: DK3181170002909248</li>
          <li>SWIFT/BIC: NYKBDKKK</li>
        </ul>
      </div>

    </div>
    
    <div class="border-t border-kv-green-800 pt-8 flex flex-col md:flex-row justify-between items-center">
      <!-- Removed Copyright Text -->
      <div class="flex space-x-6">
        <!-- Facebook -->
        <a href="https://www.facebook.com/Karmavedadk" target="_blank" rel="noopener noreferrer" class="text-kv-earth-400 hover:text-white transition-colors">
          <span class="sr-only">Facebook</span>
