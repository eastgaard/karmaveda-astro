---
// src/components/PageHero.astro
interface Props {
  isLarge?: boolean;
}

const { isLarge = false } = Astro.props;
const paddingClasses = isLarge ? "pt-32 pb-32 lg:pt-48 lg:pb-48" : "pt-32 pb-24";
---

<section class={`relative w-full bg-gradient-to-br from-kv-earth-50 via-kv-earth-100 to-kv-earth-200 bg-[length:200%_200%] animate-gradient-shift border-b border-kv-earth-300/50 overflow-hidden ${paddingClasses}`}>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <slot />
  </div>
  
  <!-- Decorative subtle pattern -->
  <svg class="absolute top-0 right-0 -mr-20 -mt-20 h-96 w-96 text-kv-earth-300 opacity-20 animate-float pointer-events-none" fill="currentColor" viewBox="0 0 100 100">
    <circle cx="50" cy="50" r="50" />
  </svg>
  <svg class="absolute bottom-0 left-0 -ml-20 -mb-20 h-96 w-96 text-kv-earth-300 opacity-20 animate-float-delayed pointer-events-none" fill="currentColor" viewBox="0 0 100 100">
    <circle cx="50" cy="50" r="50" />
  </svg>
</section>
