---
// src/components/PageHero.astro
interface Props {
  isLarge?: boolean;
  theme?: 'earth' | 'green';
}

const { isLarge = false, theme = 'earth' } = Astro.props;
const paddingClasses = isLarge ? "pt-32 pb-32 lg:pt-48 lg:pb-48" : "pt-32 pb-24";

const themeClasses = theme === 'green' 
  ? "from-kv-green-50 via-kv-green-100 to-kv-green-200 border-kv-green-300/50" 
  : "from-kv-earth-50 via-kv-earth-100 to-kv-earth-200 border-kv-earth-300/50";

const circleColor = theme === 'green' ? "text-kv-green-300" : "text-kv-earth-300";
---

<section class={`relative w-full bg-gradient-to-br ${themeClasses} bg-[length:200%_200%] animate-gradient-shift border-b overflow-hidden ${paddingClasses}`}>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <slot />
  </div>
  
  <!-- Decorative subtle pattern -->
  <svg class={`absolute top-0 right-0 -mr-20 -mt-20 h-96 w-96 ${circleColor} opacity-20 animate-float pointer-events-none`} fill="currentColor" viewBox="0 0 100 100">
    <circle cx="50" cy="50" r="50" />
  </svg>
  <svg class={`absolute bottom-0 left-0 -ml-20 -mb-20 h-96 w-96 ${circleColor} opacity-20 animate-float-delayed pointer-events-none`} fill="currentColor" viewBox="0 0 100 100">
    <circle cx="50" cy="50" r="50" />
  </svg>
</section>
