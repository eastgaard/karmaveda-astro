---
// src/components/Header.astro
import Logo from './Logo.astro';

const navItems = [
  { label: 'Forside', href: '/' },
  {
    label: 'Behandlinger',
    href: '#',
    children: [
      { label: 'Oversigt & Priser', href: '/behandlinger' },
      { label: 'Livsstilskonsultation', href: '/livsstilskonsultation' },
      { label: 'Personlige Meditationer', href: '/skraeddersyede-meditationer' }
    ]
  },
  { label: 'Meditation', href: '/meditation' },
  { label: 'Om Karmaveda', href: '/om-os' },
  { label: 'Blog', href: '/blog' },
];
---

<header class="bg-kv-earth-50/90 backdrop-blur-md sticky top-0 z-50 border-b border-kv-earth-200 shadow-sm transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex items-center text-kv-green-700 hover:text-kv-green-900 transition-colors" aria-label="Karmaveda Forside">
          <Logo className="h-14 w-14" />
          <span class="ml-3 text-3xl font-serif tracking-wide font-medium">Karmaveda</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8 items-center">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <button class="flex items-center text-kv-text hover:text-kv-green-500 px-3 py-2 text-sm font-medium transition-colors">
                {item.label}
                <svg class="ml-1 h-4 w-4 text-kv-green-500 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              
              <!-- Dropdown Panel -->
              <div class="absolute left-0 mt-0 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-in-out pt-2">
                <div class="rounded-lg shadow-lg bg-white ring-1 ring-black ring-opacity-5 overflow-hidden">
                  <div class="py-1">
                    {item.children.map(child => (
                      <a href={child.href} class="block px-4 py-3 text-sm text-kv-text hover:bg-kv-earth-100 hover:text-kv-green-700 transition-colors">{child.label}</a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="text-kv-text hover:text-kv-green-500 px-3 py-2 text-sm font-medium transition-colors">{item.label}</a>
          )
        ))}
        
        <!-- CTA Button -->
        <a href="/om-os" class="ml-4 inline-flex items-center justify-center px-6 py-2.5 border border-transparent rounded-full shadow-sm text-sm font-medium text-white bg-kv-green-500 hover:bg-kv-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-kv-green-500 transition-colors">
          Kontakt
        </a>
      </nav>

      <!-- Mobile menu button -->
      <div class="flex items-center md:hidden">
        <button id="mobile-menu-btn" class="text-kv-text hover:text-kv-green-500 focus:outline-none p-2" aria-expanded="false" aria-controls="mobile-menu">
          <span class="sr-only">Åbn hovedmenu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-kv-earth-100 absolute w-full shadow-lg">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      {navItems.map((item) => (
        item.children ? (
          <div class="pl-3">
            <div class="px-3 py-2 text-base font-medium text-kv-text opacity-70 border-b border-kv-earth-100">{item.label}</div>
            <div class="pl-4 py-2 space-y-1">
              {item.children.map(child => (
                <a href={child.href} class="block px-3 py-2 text-sm font-medium text-kv-text hover:text-kv-green-500 hover:bg-kv-earth-50 rounded-md transition-colors">{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="block px-3 py-2 rounded-md text-base font-medium text-kv-text hover:text-kv-green-500 hover:bg-kv-earth-50 transition-colors">{item.label}</a>
        )
      ))}
      <a href="/om-os" class="block w-full mt-4 text-center px-4 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-kv-green-500 hover:bg-kv-green-700 transition-colors">
        Kontakt
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  if (btn && menu && menuIcon && closeIcon) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      menuIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      const expanded = btn.getAttribute('aria-expanded') === 'true' || false;
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  }
</script>
